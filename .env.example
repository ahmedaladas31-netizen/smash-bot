# انسخ هذا الملف إلى .env ثم ضع قيم مشروعك من Supabase
# Project Settings > API

# رابط المشروع (Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# المفتاح العام (anon / public key) — وليس الـ service_role
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# رابط الـ webhook لإرسال الردود الجاهزة للزبون (n8n)
VITE_WEBHOOK_URL=https://darkbyte.app.n8n.cloud/webhook/smash-send
