# انسخ هذا الملف إلى .env ثم ضع قيم مشروعك من Supabase
# Project Settings > API

# رابط المشروع (Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# المفتاح العام (anon / public key) — وليس الـ service_role
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# رابط الـ webhook لإرسال الردود الجاهزة للزبون (n8n)
VITE_WEBHOOK_URL=https://darkbyte.app.n8n.cloud/webhook/smash-send

# توكن سري مشترك مع n8n (عقدة Check Token في workflow الإرسال).
# يجب أن تكون نفس القيمة هنا وفي n8n. ولّد واحداً جديداً عبر:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
VITE_WEBHOOK_TOKEN=your-shared-secret-token
